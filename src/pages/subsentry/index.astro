---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---
<Layout title="SubSentry — Subscription Tracker for iPhone" description="The privacy-first subscription tracker for iPhone. Track spending, get insights, never miss a payment.">
  <div class="max-w-3xl mx-auto px-5 py-16">
    
    <!-- Hero -->
    <div class="text-center mb-12">
      <img src="/subsentry-icon.png" alt="SubSentry" class="w-24 h-24 mx-auto mb-6 rounded-2xl shadow-lg shadow-blue-500/20" />
      <h1 class="text-5xl font-bold mb-3">
        <span class="bg-gradient-to-r from-blue-400 to-purple-500 bg-clip-text text-transparent">SubSentry</span>
      </h1>
      <p class="text-xl text-blue-200/80 mb-2">Know exactly where your money goes.</p>
      <p class="text-white/50">The privacy-first subscription tracker for iPhone.</p>
    </div>

    <!-- App Store badge placeholder -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-2 rounded-full border border-white/10 text-white/40 text-sm">Coming soon to the App Store</span>
    </div>

    <!-- Features -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-16">
      <div class="rounded-xl p-6 border border-white/10 bg-white/5 backdrop-blur-sm">
        <div class="text-2xl mb-3">🔒</div>
        <h3 class="text-lg font-semibold text-white mb-2">Privacy First</h3>
        <p class="text-white/50 text-sm leading-relaxed">No bank logins. No account linking. Your data stays on your device and in your iCloud — we never see it.</p>
      </div>
      
      <div class="rounded-xl p-6 border border-white/10 bg-white/5 backdrop-blur-sm">
        <div class="text-2xl mb-3">📧</div>
        <h3 class="text-lg font-semibold text-white mb-2">Smart Import</h3>
        <p class="text-white/50 text-sm leading-relaxed">Snap a screenshot of a receipt or forward a confirmation email — AI detects the subscription details automatically.</p>
      </div>
      
      <div class="rounded-xl p-6 border border-white/10 bg-white/5 backdrop-blur-sm">
        <div class="text-2xl mb-3">📊</div>
        <h3 class="text-lg font-semibold text-white mb-2">Spending Analytics</h3>
        <p class="text-white/50 text-sm leading-relaxed">See where your money goes with category breakdowns, spending trends, and budget tracking.</p>
      </div>
      
      <div class="rounded-xl p-6 border border-white/10 bg-white/5 backdrop-blur-sm">
        <div class="text-2xl mb-3">🔔</div>
        <h3 class="text-lg font-semibold text-white mb-2">Payment Reminders</h3>
        <p class="text-white/50 text-sm leading-relaxed">Never get surprised by a charge. Get notified before every renewal date.</p>
      </div>
      
      <div class="rounded-xl p-6 border border-white/10 bg-white/5 backdrop-blur-sm">
        <div class="text-2xl mb-3">💡</div>
        <h3 class="text-lg font-semibold text-white mb-2">Smart Insights</h3>
        <p class="text-white/50 text-sm leading-relaxed">Get personalized recommendations to cut spending — duplicate services, unused subscriptions, annual plan savings.</p>
      </div>
      
      <div class="rounded-xl p-6 border border-white/10 bg-white/5 backdrop-blur-sm">
        <div class="text-2xl mb-3">🤖</div>
        <h3 class="text-lg font-semibold text-white mb-2">AI Negotiator</h3>
        <p class="text-white/50 text-sm leading-relaxed">Get custom scripts to negotiate lower rates on your biggest subscriptions. Premium feature.</p>
      </div>
    </div>

    <!-- Pricing -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white text-center mb-8">Simple Pricing</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="rounded-xl p-6 border border-white/10 bg-white/5 text-center">
          <p class="text-white/40 text-sm mb-1">Free</p>
          <p class="text-3xl font-bold text-white">$0</p>
          <p class="text-white/30 text-xs mt-2">Up to 25 subscriptions</p>
        </div>
        <div class="rounded-xl p-6 border border-blue-400/40 bg-blue-500/10 text-center relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="px-3 py-1 bg-blue-500 text-white text-xs font-semibold rounded-full">POPULAR</span>
          </div>
          <p class="text-blue-300 text-sm mb-1 font-medium">Premium</p>
          <p class="text-3xl font-bold text-white">$4.99<span class="text-base font-normal text-white/40">/mo</span></p>
          <p class="text-white/30 text-xs mt-2">or $29.99/year (save 50%)</p>
        </div>
        <div class="rounded-xl p-6 border border-white/10 bg-white/5 text-center">
          <p class="text-white/40 text-sm mb-1">Lifetime</p>
          <p class="text-3xl font-bold text-white">$39.99</p>
          <p class="text-white/30 text-xs mt-2">One-time purchase</p>
        </div>
      </div>
      <p class="text-white/25 text-xs mt-4 text-center">7-day free trial on all premium plans</p>
    </div>

    <!-- Footer links -->
    <div class="border-t border-white/10 pt-8 text-center space-y-3">
      <p class="text-sm">
        <a href="/subsentry/privacy-policy" class="text-white/40 hover:text-white transition">Privacy Policy</a>
        <span class="mx-3 text-white/20">·</span>
        <a href="/subsentry/terms-of-service" class="text-white/40 hover:text-white transition">Terms of Service</a>
      </p>
      <p class="text-xs text-white/20">Built by <a href="/" class="text-white/30 hover:text-white transition">Justin Bundrick</a></p>
      <p class="text-xs text-white/20">Questions? <a href="mailto:bunjisolutions@gmail.com" class="text-white/30 hover:text-white transition">bunjisolutions@gmail.com</a></p>
    </div>
  </div>
</Layout>
