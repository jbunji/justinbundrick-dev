---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="SubSentry — Subscription Tracker for iPhone">
  <div class="max-w-2xl mx-auto px-5 py-12 text-center">
    
    <!-- Hero -->
    <div class="mb-10">
      <div class="text-6xl mb-4">🛡️</div>
      <h1 class="text-4xl font-bold mb-3 bg-gradient-to-r from-blue-400 to-purple-500 bg-clip-text text-transparent">SubSentry</h1>
      <p class="text-xl text-gray-300">Know exactly where your money goes.</p>
      <p class="text-gray-400 mt-2">The privacy-first subscription tracker for iPhone.</p>
    </div>

    <!-- App Store badge placeholder -->
    <div class="mb-12">
      <p class="text-gray-500 text-sm">Coming soon to the App Store</p>
    </div>

    <!-- Features -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-left mb-12">
      <div class="bg-gray-800/50 rounded-xl p-6 border border-gray-700/50">
        <div class="text-2xl mb-2">🔒</div>
        <h3 class="text-lg font-semibold text-white mb-1">Privacy First</h3>
        <p class="text-gray-400 text-sm">No bank logins. No account linking. Your data stays on your device and in your iCloud — we never see it.</p>
      </div>
      
      <div class="bg-gray-800/50 rounded-xl p-6 border border-gray-700/50">
        <div class="text-2xl mb-2">📧</div>
        <h3 class="text-lg font-semibold text-white mb-1">Smart Import</h3>
        <p class="text-gray-400 text-sm">Snap a screenshot of a receipt or forward a confirmation email — AI detects the subscription details automatically.</p>
      </div>
      
      <div class="bg-gray-800/50 rounded-xl p-6 border border-gray-700/50">
        <div class="text-2xl mb-2">📊</div>
        <h3 class="text-lg font-semibold text-white mb-1">Spending Analytics</h3>
        <p class="text-gray-400 text-sm">See where your money goes with category breakdowns, spending trends, and budget tracking.</p>
      </div>
      
      <div class="bg-gray-800/50 rounded-xl p-6 border border-gray-700/50">
        <div class="text-2xl mb-2">🔔</div>
        <h3 class="text-lg font-semibold text-white mb-1">Payment Reminders</h3>
        <p class="text-gray-400 text-sm">Never get surprised by a charge. Get notified before every renewal date.</p>
      </div>
      
      <div class="bg-gray-800/50 rounded-xl p-6 border border-gray-700/50">
        <div class="text-2xl mb-2">💡</div>
        <h3 class="text-lg font-semibold text-white mb-1">Smart Insights</h3>
        <p class="text-gray-400 text-sm">Get personalized recommendations to cut spending — duplicate services, unused subscriptions, annual plan savings.</p>
      </div>
      
      <div class="bg-gray-800/50 rounded-xl p-6 border border-gray-700/50">
        <div class="text-2xl mb-2">🤖</div>
        <h3 class="text-lg font-semibold text-white mb-1">AI Negotiator</h3>
        <p class="text-gray-400 text-sm">Get custom scripts to negotiate lower rates on your biggest subscriptions. Premium feature.</p>
      </div>
    </div>

    <!-- Pricing -->
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-white mb-6">Simple Pricing</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-gray-800/50 rounded-xl p-5 border border-gray-700/50">
          <p class="text-gray-400 text-sm mb-1">Free</p>
          <p class="text-2xl font-bold text-white">$0</p>
          <p class="text-gray-500 text-xs mt-1">Up to 25 subscriptions</p>
        </div>
        <div class="bg-gray-800/50 rounded-xl p-5 border border-blue-500/50 ring-1 ring-blue-500/30">
          <p class="text-blue-400 text-sm mb-1 font-medium">Premium</p>
          <p class="text-2xl font-bold text-white">$4.99<span class="text-sm font-normal text-gray-400">/mo</span></p>
          <p class="text-gray-500 text-xs mt-1">or $29.99/year (save 50%)</p>
        </div>
        <div class="bg-gray-800/50 rounded-xl p-5 border border-gray-700/50">
          <p class="text-gray-400 text-sm mb-1">Lifetime</p>
          <p class="text-2xl font-bold text-white">$39.99</p>
          <p class="text-gray-500 text-xs mt-1">One-time purchase</p>
        </div>
      </div>
      <p class="text-gray-500 text-xs mt-3">7-day free trial on all premium plans</p>
    </div>

    <!-- Footer links -->
    <div class="border-t border-gray-800 pt-8 space-y-2">
      <p class="text-gray-500 text-sm">
        <a href="/subsentry/privacy-policy" class="text-gray-400 hover:text-white transition">Privacy Policy</a>
        <span class="mx-2">·</span>
        <a href="/subsentry/terms-of-service" class="text-gray-400 hover:text-white transition">Terms of Service</a>
      </p>
      <p class="text-gray-600 text-xs">Built by <a href="/" class="text-gray-500 hover:text-white transition">Justin Bundrick</a></p>
      <p class="text-gray-600 text-xs">Questions? <a href="mailto:bunjisolutions@gmail.com" class="text-gray-500 hover:text-white transition">bunjisolutions@gmail.com</a></p>
    </div>
  </div>
</Layout>
