---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const apps = [
  {
    name: 'PlantPal',
    tagline: 'Never kill another plant',
    description: 'AI-powered plant care assistant. Identify any plant, get custom watering schedules, and receive reminders before your plants need attention.',
    icon: '/icons/plantpal.png',
    color: 'from-green-500/20 to-emerald-600/10 border-green-500/30',
    status: 'live',
    storeUrl: 'https://apps.apple.com/app/id6760488449',
    features: ['AI Plant Identification', 'Custom Care Schedules', 'Watering Reminders', 'Plant Health Tracking'],
  },
  {
    name: 'ChoreQuest',
    tagline: 'Make chores fun for the whole family',
    description: 'Turn household chores into a family adventure. Assign tasks, earn points, level up — gamified cleaning that kids actually want to do.',
    icon: '/icons/chorequest.png',
    color: 'from-purple-500/20 to-violet-600/10 border-purple-500/30',
    status: 'live',
    storeUrl: 'https://apps.apple.com/app/id6759983257',
    features: ['Family Chore Boards', 'Points & Rewards', 'Kid-Friendly UI', 'Progress Tracking'],
  },
  {
    name: 'HabitForge',
    tagline: 'AI turns any goal into daily habits',
    description: 'Tell it your goal. AI creates a phased plan with daily habits that evolve as you progress. Built-in AI coach keeps you accountable.',
    icon: '/icons/habitforge.png',
    color: 'from-blue-500/20 to-cyan-600/10 border-blue-500/30',
    status: 'live',
    storeUrl: 'https://apps.apple.com/app/id6751129821',
    features: ['AI Plan Generator', 'Phased Journey Timeline', 'AI Coach Insights', 'Achievement System'],
  },
  {
    name: 'SubSentry',
    tagline: 'Stop wasting money on forgotten subscriptions',
    description: 'Track every subscription in one place. Get alerts before renewals, see your true monthly spend, and cancel what you don\'t use.',
    icon: '/icons/subsentry.png',
    color: 'from-amber-500/20 to-orange-600/10 border-amber-500/30',
    status: 'coming',
    storeUrl: '#',
    features: ['Subscription Tracking', 'Renewal Alerts', 'Spending Analytics', 'Cancel Reminders'],
  },
  {
    name: 'Upkeepy',
    tagline: 'Your home maintenance co-pilot',
    description: 'Never forget an oil change, filter replacement, or seasonal maintenance task. Smart reminders for everything in your home.',
    icon: '/icons/upkeepy.png',
    color: 'from-slate-500/20 to-gray-600/10 border-slate-500/30',
    status: 'live',
    storeUrl: 'https://apps.apple.com/app/id6760043465',
    features: ['Home Task Library', 'Smart Reminders', 'Maintenance History', 'Seasonal Schedules'],
  },
];

const liveApps = apps.filter(a => a.status === 'live');
const comingApps = apps.filter(a => a.status === 'coming');
---

<Layout title="Apps — Bunji Studios" description="iOS apps built by Justin Bundrick. Productivity, plant care, habits, and more.">
  <div class="min-h-screen bg-[#0a0e1a]">
    <!-- Header -->
    <header class="border-b border-white/10">
      <div class="max-w-5xl mx-auto px-6 py-6 flex items-center justify-between">
        <a href="/" class="text-white/60 hover:text-white transition-colors text-sm">
          ← justinbundrick.dev
        </a>
        <div class="flex items-center gap-3">
          <span class="text-2xl">📱</span>
          <div>
            <h1 class="text-white font-bold text-lg">Bunji Studios</h1>
            <p class="text-white/40 text-xs">Apps by Justin Bundrick</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <section class="max-w-5xl mx-auto px-6 py-16 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Apps that make life <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-cyan-400">a little easier</span>
      </h2>
      <p class="text-white/50 text-lg max-w-2xl mx-auto">
        Built by one developer with AI. Simple tools that solve real problems. All free to download.
      </p>
    </section>

    <!-- Live Apps -->
    <section class="max-w-5xl mx-auto px-6 pb-12">
      <div class="flex items-center gap-3 mb-8">
        <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-500/10 border border-green-500/30 text-green-400 text-sm font-medium">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          Live on the App Store
        </span>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {liveApps.map((app) => (
          <a href={app.storeUrl} target="_blank" rel="noopener" 
             class={`group block p-6 rounded-2xl bg-gradient-to-br ${app.color} border backdrop-blur-sm hover:scale-[1.02] transition-all duration-300`}>
            <div class="flex items-start justify-between mb-4">
              <img src={app.icon} alt={app.name} class="w-16 h-16 rounded-2xl shadow-lg" />
              <span class="text-xs px-2 py-1 rounded-full bg-green-500/20 text-green-400 border border-green-500/20">
                FREE
              </span>
            </div>
            <h3 class="text-white font-bold text-xl mb-1">{app.name}</h3>
            <p class="text-white/60 text-sm mb-4">{app.tagline}</p>
            <p class="text-white/40 text-sm mb-4">{app.description}</p>
            <div class="flex flex-wrap gap-2">
              {app.features.map((f) => (
                <span class="text-xs px-2 py-1 rounded-md bg-white/5 text-white/50">{f}</span>
              ))}
            </div>
            <div class="mt-4 flex items-center gap-2 text-white/30 group-hover:text-white/60 transition-colors text-sm">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              Download on App Store →
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Coming Soon -->
    {comingApps.length > 0 && (
      <section class="max-w-5xl mx-auto px-6 pb-16">
        <div class="flex items-center gap-3 mb-8">
          <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-400 text-sm font-medium">
            🚧 Coming Soon
          </span>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {comingApps.map((app) => (
            <div class={`p-6 rounded-2xl bg-gradient-to-br ${app.color} border backdrop-blur-sm opacity-70`}>
              <div class="flex items-start justify-between mb-4">
                <img src={app.icon} alt={app.name} class="w-16 h-16 rounded-2xl shadow-lg" />
                <span class="text-xs px-2 py-1 rounded-full bg-amber-500/20 text-amber-400 border border-amber-500/20">
                  SOON
                </span>
              </div>
              <h3 class="text-white font-bold text-xl mb-1">{app.name}</h3>
              <p class="text-white/60 text-sm mb-4">{app.tagline}</p>
              <p class="text-white/40 text-sm">{app.description}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Footer -->
    <footer class="border-t border-white/10 py-8">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <p class="text-white/30 text-sm">
          Built with ❤️ by <a href="/" class="text-white/50 hover:text-white transition-colors">Justin Bundrick</a>
        </p>
        <div class="flex items-center justify-center gap-4 mt-3">
          <a href="https://x.com/BunjiStudios" target="_blank" rel="noopener" class="text-white/30 hover:text-white/60 transition-colors text-sm">
            𝕏 @BunjiStudios
          </a>
        </div>
      </div>
    </footer>
  </div>
</Layout>
